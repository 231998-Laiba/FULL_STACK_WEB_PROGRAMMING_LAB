{
  "name": "lab-14-api-testing",
  "version": "1.0.0",
  "description": "Lab 14 - RESTful API Deployment and Testing: Weather Forecast API + News Headlines API with Jest testing",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest tests/unit --runInBand --forceExit",
    "test:integration": "jest tests/integration --runInBand --forceExit",
    "test:system": "jest tests/system --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit"
  },
  "keywords": ["REST", "API", "Weather", "News", "Jest", "Testing", "Express"],
  "author": "Aliza Zaman",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 15000,
    "verbose": true,
    "collectCoverageFrom": [
      "controllers/**/*.js",
      "services/**/*.js",
      "utils/**/*.js",
      "middleware/**/*.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "html"]
  }
}
